# ============================================================
# Copy this file to ".env.local" and fill in your real values.
# .env.local is git-ignored, so your secrets never get committed.
# The site runs fine WITHOUT any of these (the blog just shows
# sample posts until you connect Notion).
# ============================================================

# ---- Your business details (shown on the site) ----
NEXT_PUBLIC_SITE_NAME="Mehak Language Lounge"
NEXT_PUBLIC_SITE_URL="https://YOUR-DOMAIN.com"
NEXT_PUBLIC_CITY="Amritsar"
NEXT_PUBLIC_STATE="Punjab"

# ---- How inquiries reach you (no database — goes straight to you) ----
# WhatsApp number: country code + number, digits only, no "+" or spaces.
# India example: 919812345678
NEXT_PUBLIC_WHATSAPP="91XXXXXXXXXX"
NEXT_PUBLIC_EMAIL="hello@your-domain.com"
NEXT_PUBLIC_YOUTUBE="https://www.youtube.com/@Mehak.Language.Lounge"
NEXT_PUBLIC_INSTAGRAM="https://www.instagram.com/mehaklanguagelounge/"
# Optional — the footer shows LinkedIn/Facebook links once these are filled in.
NEXT_PUBLIC_LINKEDIN=""
NEXT_PUBLIC_FACEBOOK=""

# Interactive 3D model (.glb). Defaults to the self-hosted /models/buddy.glb
# (CC0 KayKit character waving). Shown on desktop only — phones skip 3D for speed.
# To use your own free model: put a .glb in public/models and set the path here.
# Free/no-copyright sources: readyplayer.me, poly.pizza (filter CC0), quaternius.com.
NEXT_PUBLIC_MODEL_URL=""

# ---- Notion blog (optional — leave blank to use sample posts) ----
# 1. Create an integration at https://www.notion.so/my-integrations
# 2. Copy its "Internal Integration Secret" here.
# 3. Share your blog database with the integration, and paste its ID below.
NOTION_TOKEN=""
NOTION_DATABASE_ID=""

# ---- Google AdSense (optional) ----
# Your publisher ID, e.g. ca-pub-1234567890123456
NEXT_PUBLIC_ADSENSE_CLIENT=""
